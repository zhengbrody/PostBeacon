# Pick any one (or more). The UI lets you switch provider per request.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...

# Optional model overrides
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o
DEEPSEEK_MODEL=deepseek-chat

# Optional: which provider the UI selects first (claude | openai | deepseek)
# Unclear-policy providers such as DeepSeek cannot silently outrank a configured
# clear-policy provider; users can still select them explicitly per run.
DEFAULT_PROVIDER=openai

# Explicit public beta opt-in: lets DeepSeek receive an automatic retry if the
# primary provider fails. The UI and legal pages disclose the same setting.
# NEXT_PUBLIC_DEEPSEEK_FALLBACK=true

# Optional signed-out one-channel preview. This remains unavailable unless
# every required value is present. The shared Redis quota is atomic and fails
# closed before scraping/model calls; Redis never receives the URL, page text,
# IP, user agent or draft. Use at least 32 random bytes for the signing secret.
# GUEST_PREVIEW_ENABLED=true
# GUEST_PREVIEW_SIGNING_SECRET=replace-with-at-least-32-random-bytes
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...
# GUEST_PREVIEW_PER_VISITOR_LIMIT=1
# GUEST_PREVIEW_GLOBAL_LIMIT=25
# GUEST_PREVIEW_WINDOW_SECONDS=86400
# GUEST_PREVIEW_TOKEN_MAX_AGE_SECONDS=2592000
# Required only if signed-out previews may retry through DeepSeek.
# GUEST_PREVIEW_ALLOW_DEEPSEEK=true

# Public, monitored address shown on legal pages. Leave unset until inbound mail
# is working; the site falls back to the GitHub feedback link.
# NEXT_PUBLIC_PRIVACY_EMAIL=privacy@postbeacon.app

# Optional event emails (24h, 72h, weekly review). Configure and verify the
# server values first, then set the public flag last so the opt-in never points
# at an incomplete delivery path. The server still fails closed without every key.
# NEXT_PUBLIC_EMAIL_REMINDERS_ENABLED=true
# RESEND_API_KEY=re_...                     # server-only
# REMINDER_FROM_EMAIL=PostBeacon <reminders@postbeacon.app>
# CRON_SECRET=...                           # shared by retention + reminder crons

# --- SaaS backend (optional). Without these, the app runs but can't save projects. ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- Metering & billing (optional). Without the service-role key, generation is
#     open and unmetered (current behavior). With it, free plan = N launches, then paywall. ---
# SUPABASE_SERVICE_ROLE_KEY=eyJ...           # server-only, Production only; bypasses RLS
# POLAR_ACCESS_TOKEN=polar_at_...            # Polar (merchant-of-record) API token
# POLAR_PRODUCT_ID=...                       # the Pro product id; webhook events for other products are ignored
# POLAR_WEBHOOK_SECRET=whsec_...             # REQUIRED for the webhook: without it /api/billing/webhook fails closed (503)

# Origins allowed as the post-checkout redirect target (comma-separated; the
# first entry is canonical). The checkout route never trusts the Origin header
# outside this list.
# SITE_URL=https://postbeacon.app,http://localhost:3000

# --- Live niche-channel discovery (optional). Without it, discovery falls back to
#     LLM-only suggestions (unvalidated). Tavily search key grounds it in real results. ---
# SEARCH_API_KEY=
# SEARCH_API_URL=https://api.tavily.com/search   # override only if needed

# --- SPA scraping (optional). Without it, scraping is static-only; client-rendered
#     landing pages (React/Vite SPAs) may come back empty. Firecrawl scrape API key. ---
# SCRAPE_API_KEY=
# SCRAPE_API_URL=https://api.firecrawl.dev/v1/scrape   # override only if needed
